<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Verify your email</title>
</head>
<body style="font-family: Arial, sans-serif; background:#f4f4f4; padding:40px;">
  <div style="max-width:480px; margin:0 auto; background:#fff; border-radius:8px; padding:32px;">
    <h2 style="color:#1a1a1a;">Hi {{firstName}},</h2>
    <p style="color:#444;">Welcome to Apardex! Use the OTP below to verify your email address.</p>
    <div style="text-align:center; margin:32px 0;">
      <span style="font-size:36px; font-weight:bold; letter-spacing:8px; color:#1a1a1a;">{{otp}}</span>
    </div>
    <p style="color:#888; font-size:13px;">This OTP expires in 10 minutes. If you didn't create an account, please ignore this email.</p>
  </div>
</body>
</html>
